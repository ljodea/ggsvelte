{
  // Type context for the held-out eval harness (bun runs the TS directly;
  // NOT part of the tsc -b build graph). tests/evals is not a workspace, so
  // "@ggsvelte/spec" / "@ggsvelte/core" resolve through these paths — Bun
  // honors tsconfig paths at runtime and maps the .d.ts entries onto the
  // sibling built dist/*.js (run `bun run check` first if dist/ is missing).
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "types": ["bun"],
    "paths": {
      "@ggsvelte/spec": ["../../packages/spec/dist/index.d.ts"],
      "@ggsvelte/core": ["../../packages/core/dist/index.d.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
