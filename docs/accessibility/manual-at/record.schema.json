{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ggsvelte.dev/schemas/manual-at-record.json",
  "title": "ggsvelte manual assistive-technology release record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "release",
    "testedCommit",
    "completedAt",
    "acceptedIssues",
    "runs",
    "notes"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "release": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "testedCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "completedAt": { "type": "string", "format": "date" },
    "acceptedIssues": {
      "type": "array",
      "items": { "$ref": "#/$defs/acceptedIssue" }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/run" }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reducedMotion",
        "contrast",
        "browserZoomPercent",
        "largePointer",
        "input",
        "viewportCssPixels"
      ],
      "properties": {
        "reducedMotion": { "type": "boolean" },
        "contrast": { "enum": ["default", "high-contrast", "forced-colors"] },
        "browserZoomPercent": { "type": "integer", "minimum": 25, "maximum": 500 },
        "largePointer": { "type": "boolean" },
        "input": { "enum": ["keyboard-pointer", "touch-only"] },
        "viewportCssPixels": { "type": "string", "pattern": "^[1-9][0-9]*x[1-9][0-9]*$" }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "observed", "result", "acceptedIssue"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "observed": { "type": "string" },
        "result": { "enum": ["pending", "pass", "fail", "blocked", "accepted"] },
        "acceptedIssue": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "fixture", "observations", "notes"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "fixture": { "type": "string", "pattern": "^/" },
        "observations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/observation" }
        },
        "notes": { "type": "string" }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "pairing",
        "date",
        "tester",
        "platform",
        "assistiveTechnology",
        "browser",
        "profile",
        "settings",
        "flows",
        "notes"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "pairing": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "date": { "type": "string", "format": "date" },
        "tester": { "type": "string", "minLength": 1 },
        "platform": { "$ref": "#/$defs/platform" },
        "assistiveTechnology": { "$ref": "#/$defs/product" },
        "browser": { "$ref": "#/$defs/product" },
        "profile": {
          "enum": [
            "baseline",
            "reduced-motion",
            "high-contrast",
            "forced-colors",
            "browser-zoom-200",
            "large-pointer",
            "touch-only"
          ]
        },
        "settings": { "$ref": "#/$defs/settings" },
        "flows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/flow" }
        },
        "notes": { "type": "string" }
      }
    },
    "acceptedIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "disposition", "acceptedBy", "acceptedAt", "rationale", "scope"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "url": { "type": "string", "format": "uri" },
        "disposition": { "const": "accepted-for-release" },
        "acceptedBy": { "type": "string", "minLength": 1 },
        "acceptedAt": { "type": "string", "format": "date" },
        "rationale": { "type": "string", "minLength": 1 },
        "scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+/[a-z0-9-]+$" }
        }
      }
    }
  }
}
