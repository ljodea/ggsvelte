{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ggsvelte.dev/schemas/manual-at-record.json",
  "title": "ggsvelte manual assistive-technology verification record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release",
    "date",
    "tester",
    "platform",
    "assistiveTechnology",
    "browser",
    "fixture",
    "reducedMotion",
    "checks",
    "notes"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "release": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "format": "date" },
    "tester": { "type": "string", "minLength": 1 },
    "platform": { "type": "string", "minLength": 1 },
    "assistiveTechnology": { "$ref": "#/$defs/product" },
    "browser": { "$ref": "#/$defs/product" },
    "fixture": { "type": "string", "minLength": 1 },
    "reducedMotion": { "type": "boolean" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "steps", "expected", "observed", "result", "issue"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "expected": { "type": "string", "minLength": 1 },
        "observed": { "type": "string" },
        "result": { "enum": ["pending", "pass", "fail", "blocked"] },
        "issue": { "type": ["string", "null"], "format": "uri" }
      }
    }
  }
}
