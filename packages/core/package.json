{
  "name": "@ggsvelte/core",
  "version": "0.1.1",
  "description": "ggsvelte core: framework-agnostic grammar-of-graphics pipeline, scale stability, layout, and the pure SVG-string renderer.",
  "keywords": [
    "canvas",
    "charts",
    "dataviz",
    "ggplot2",
    "grammar-of-graphics",
    "headless",
    "plot",
    "ssr",
    "svg",
    "visualization"
  ],
  "homepage": "https://github.com/ljodea/ggsvelte",
  "bugs": "https://github.com/ljodea/ggsvelte/issues",
  "license": "MIT",
  "author": "Liam O'Dea",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ljodea/ggsvelte.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dom": {
      "types": "./dist/dom/index.d.ts",
      "default": "./dist/dom/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ggsvelte/spec": "^0.1.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
