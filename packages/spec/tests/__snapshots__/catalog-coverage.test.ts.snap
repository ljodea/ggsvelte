exports[`ERROR_CATALOG coverage [facet-form-ambiguous] is reproducible; message + fix snapshot 1`] = `
{
  "catalog": {
    "fix": "Keep facet.wrap (and drop rows/cols), or keep rows/cols (and drop wrap).",
    "summary": "A facet sets BOTH the wrap form and the rows/cols grid form.",
    "tier": 2,
  },
  "instance": {
    "code": "facet-form-ambiguous",
    "fix": {
      "description": "Keep facet.wrap (and drop rows/cols), or keep rows/cols (and drop wrap).",
      "example": {
        "ncol": 3,
        "wrap": {
          "field": "group",
        },
      },
    },
    "message": "This facet mixes the wrap form (facet.wrap) with the grid form (facet.rows/facet.cols). Use wrap OR rows/cols, never both.",
    "path": "/facet",
  },
}
`;

