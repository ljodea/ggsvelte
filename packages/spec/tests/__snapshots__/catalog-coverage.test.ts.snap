// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`ERROR_CATALOG coverage [invalid-spec-root] is reproducible; message + fix snapshot 1`] = `
{
  "catalog": {
    "fix": "Provide an object with at least one layer: {"layers": [{"geom": "point", ...}]}.",
    "summary": "The spec is not a JSON object.",
    "tier": 1,
  },
  "instance": {
    "code": "invalid-spec-root",
    "fix": {
      "description": "Provide an object with at least one layer.",
      "example": {
        "layers": [
          {
            "aes": {
              "x": {
                "field": "x",
              },
              "y": {
                "field": "y",
              },
            },
            "geom": "point",
          },
        ],
      },
    },
    "message": "A plot spec must be a JSON object with a "layers" array (got number).",
    "path": "",
  },
}
`;

