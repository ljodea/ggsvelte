exports[`ERROR_CATALOG coverage [invalid-channel-value] is reproducible; message + fix snapshot 1`] = `
{
  "catalog": {
    "fix": "Wrap field mappings as {"field": "column_name"} and constants as {"value": ...}.",
    "summary": "A channel value is not one of the canonical forms {field}/{value}/{stat}/null (bare strings are builder-only shorthand).",
    "tier": 1,
  },
  "instance": {
    "code": "invalid-channel-value",
    "fix": {
      "description": "Use a canonical channel form, e.g. {"field": "column_name"} to map "x" to a data column.",
      "example": {
        "field": "displ",
      },
    },
    "message": "Channel "x" is the bare string "displ"; portable specs require the canonical form {"field": "displ"}.",
    "path": "/layers/0/aes/x",
  },
}
`;

