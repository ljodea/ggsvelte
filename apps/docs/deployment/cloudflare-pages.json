{
  "schemaVersion": 1,
  "integration": "github-actions-direct-upload",
  "workflow": ".github/workflows/cloudflare-pages.yml",
  "projectName": "ggsvelte",
  "productionBranch": "main",
  "buildCommand": "bun run build:cloudflare",
  "destinationDirectory": "apps/docs/build",
  "rootDirectory": "",
  "runtimes": {
    "BUN_VERSION": "1.3.14",
    "NODE_VERSION": "22"
  },
  "environments": {
    "production": {
      "DOCS_BUILD_MODE": "cloudflare-production"
    },
    "preview": {
      "DOCS_BUILD_MODE": "cloudflare-preview"
    }
  },
  "externalRedirects": [
    {
      "source": "https://ggsvelte.pages.dev",
      "target": "https://ggsvelte.sh",
      "status": 301,
      "preserveQueryString": true,
      "subpathMatching": true,
      "preservePathSuffix": true,
      "includeSubdomains": false
    },
    {
      "source": "https://www.ggsvelte.sh",
      "target": "https://ggsvelte.sh",
      "status": 301,
      "preserveQueryString": true,
      "subpathMatching": true,
      "preservePathSuffix": true,
      "includeSubdomains": false
    }
  ],
  "watchPaths": [
    "apps/docs/**",
    "packages/**",
    "examples/**",
    "scripts/**",
    "lifecycle.json",
    "package.json",
    "bun.lock",
    "tsconfig.json",
    "tsconfig.base.json",
    "mise.toml"
  ]
}
