{
  "schemaVersion": 1,
  "projectName": "ggsvelte",
  "productionBranch": "main",
  "buildCommand": "bun run build:cloudflare",
  "destinationDirectory": "apps/docs/build",
  "rootDirectory": "",
  "runtimes": {
    "BUN_VERSION": "1.3.14",
    "NODE_VERSION": "22"
  },
  "environments": {
    "production": {
      "DOCS_BUILD_MODE": "cloudflare-production"
    },
    "preview": {
      "DOCS_BUILD_MODE": "cloudflare-preview"
    }
  },
  "watchPaths": [
    "apps/docs/**",
    "packages/**",
    "examples/**",
    "scripts/**",
    "lifecycle.json",
    "package.json",
    "bun.lock",
    "tsconfig.json",
    "tsconfig.base.json",
    "mise.toml"
  ]
}
