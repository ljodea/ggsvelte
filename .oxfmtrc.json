{
  // oxfmt owns ts/js/json/jsonc/css/toml (its native Rust paths). It does
  // NOT own .svelte/.md/.yaml here: oxfmt 0.58 routes those through embedded
  // prettier plugins, which throw DataCloneError under the bun runtime — and
  // bun is the only runtime that can load this repo's native bindings on
  // arm64 dev machines. Those extensions go to prettier directly
  // (prettier-plugin-svelte for .svelte — the plan's pre-decided fallback).
  // See CONTRIBUTING.md.
  "ignorePatterns": [
    "spikes/**",
    // generated artifact (emit-schema.ts owns its formatting; a staleness
    // test compares it byte-for-byte against a fresh build)
    "packages/spec/schema/**",
    "bun.lock",
    ".changeset/**",
    "**/*.md",
    "**/*.svelte",
    "**/*.yml",
    "**/*.yaml",
    // same embedded-prettier DataCloneError under bun as .svelte/.md; the
    // only .html is apps/docs/src/app.html (SvelteKit template)
    "**/*.html",
    // generated + build output
    "apps/docs/.svelte-kit/**",
    "apps/docs/build/**",
    // examples/manifest.ts is generated by scripts/gen-manifest.ts, which
    // owns its bytes (manifest:check compares byte-for-byte)
    "examples/manifest.ts",
    // lifecycle.json is generated by scripts/gen-lifecycle.ts, which owns
    // its bytes (lifecycle:check + a staleness test compare byte-for-byte)
    "lifecycle.json"
  ]
}
